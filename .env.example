# Copy to .env.local and fill in from your Supabase project dashboard.
# Project settings -> API. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses row level security — keep it out of the browser and out of git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated emails allowed to use the admin API (must exist as Supabase Auth users).
ADMIN_EMAILS=owner@example.com

# 32-byte hex key for app-level CNIC encryption (AES-256-GCM). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Losing this key makes stored CNICs unreadable forever — keep a copy in a password manager.
CNIC_ENCRYPTION_KEY=generate-me-64-hex-chars
